{
  "headers": [
    {
      "source": "/(.+\\.(?:jpg|jpeg|png|gif|webp|avif|svg|ico|mp4|webm|mp3|woff|woff2|ttf|otf))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
